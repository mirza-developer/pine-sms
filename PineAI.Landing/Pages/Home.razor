<!-- ═══════════════════════════════ CONTACT ════════════════════════════════ -->
<section class="contact-section section" id="contact" aria-labelledby="contact-title">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">تماس با ما</span>
            <h2 id="contact-title">دمو رایگان درخواست کنید</h2>
            <p class="section-desc">
                اطلاعات خود را وارد کنید. تیم ما در اسرع وقت با شما تماس می‌گیرد.
            </p>
        </div>

        <div class="contact-form-wrap">
            @if (formSubmitted)
            {
                <div class="form-success" role="alert" aria-live="polite">
                    <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22,4 12,14.01 9,11.01"/>
                    </svg>
                    <h3>درخواست شما با موفقیت ثبت شد!</h3>
                    <p>تیم پاین‌ای به‌زودی با شما تماس خواهد گرفت.</p>
                    <button class="btn btn-ghost" @onclick="ResetForm">ثبت درخواست جدید</button>
                </div>
            }
            else
            {
                <form class="contact-form" @onsubmit="SubmitForm" @onsubmit:preventDefault novalidate>
                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="form-error" role="alert" aria-live="polite">@formError</div>
                    }

                    <div class="form-row">
                        <div class="form-group">
                            <label for="contact-name">نام و نام‌خانوادگی <span class="required" aria-hidden="true">*</span></label>
                            <input id="contact-name"
                                   type="text"
                                   class="form-input @(nameError ? "input-error" : "")"
                                   placeholder="مثال: علی احمدی"
                                   @bind="form.Name"
                                   @bind:event="oninput"
                                   maxlength="100"
                                   autocomplete="name"
                                   disabled="@isSubmitting" />
                            @if (nameError)
                            {
                                <span class="field-error" role="alert">وارد کردن نام الزامی است.</span>
                            }
                        </div>

                        <div class="form-group">
                            <label for="contact-phone">شماره تلفن <span class="required" aria-hidden="true">*</span></label>
                            <input id="contact-phone"
                                   type="tel"
                                   class="form-input @(phoneError ? "input-error" : "")"
                                   placeholder="مثال: ۰۹۱۲۱۲۳۴۵۶۷"
                                   @bind="form.Phone"
                                   @bind:event="oninput"
                                   maxlength="20"
                                   autocomplete="tel"
                                   dir="ltr"
                                   disabled="@isSubmitting" />
                            @if (phoneError)
                            {
                                <span class="field-error" role="alert">وارد کردن شماره تلفن الزامی است.</span>
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="contact-website">وب‌سایت فروشگاه <span class="optional">(اختیاری)</span></label>
                        <input id="contact-website"
                               type="url"
                               class="form-input"
                               placeholder="مثال: https://myshop.com"
                               @bind="form.Website"
                               @bind:event="oninput"
                               maxlength="200"
                               autocomplete="url"
                               dir="ltr"
                               disabled="@isSubmitting" />
                    </div>

                    <div class="form-group">
                        <label for="contact-desc">توضیحات <span class="required" aria-hidden="true">*</span></label>
                        <textarea id="contact-desc"
                                  class="form-input form-textarea @(descError ? "input-error" : "")"
                                  placeholder="بنویسید چه نیازی دارید، چند مشتری دارید و فروشگاه شما در چه حوزه‌ای فعالیت می‌کند..."
                                  @bind="form.Description"
                                  @bind:event="oninput"
                                  maxlength="1000"
                                  rows="4"
                                  disabled="@isSubmitting"></textarea>
                        @if (descError)
                        {
                            <span class="field-error" role="alert">وارد کردن توضیحات الزامی است.</span>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary btn-submit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner sm" aria-hidden="true"></span>
                            <span>در حال ارسال...</span>
                        }
                        else
                        {
                            <span>ارسال درخواست</span>
                        }
                    </button>
                </form>
            }
        </div>
    </div>
</section>

@code {
    private ContactFormDto form = new();
    private bool isSubmitting = false;
    private bool formSubmitted = false;
    private string formError = string.Empty;

    private bool nameError = false;
    private bool phoneError = false;
    private bool descError = false;

    private bool Validate()
    {
        nameError = string.IsNullOrWhiteSpace(form.Name);
        phoneError = string.IsNullOrWhiteSpace(form.Phone);
        descError = string.IsNullOrWhiteSpace(form.Description);
        return !nameError && !phoneError && !descError;
    }

    private async Task SubmitForm()
    {
        formError = string.Empty;
        if (!Validate()) return;

        isSubmitting = true;
        try
        {
            var ok = await ContactSvc.SendMessageAsync(form, CancellationToken.None);
            if (ok)
            {
                formSubmitted = true;
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        form = new();
        formSubmitted = false;
        formError = string.Empty;
        nameError = false;
        phoneError = false;
        descError = false;
    }
}
