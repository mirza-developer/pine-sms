<header class="site-header" id="header-main" role="banner">
    <div class="header-main-bar" id="header-main">
        <div class="container header-inner">
            <div class="header-logo">
                @if(!string.IsNullOrEmpty(Business.LogoUrl))
                {
                    <a href="@Business.WebsiteUrl" target="_blank" rel="noopener" class="logo-link">
                        <img src="@Business.LogoUrl"
                             class="site-logo" alt="@Business.LogoAlt"
                             fetchpriority="high" decoding="async"
                             width="160" height="48" />
                    </a>
                }
            </div>
            <nav class="header-nav" role="navigation" aria-label="منوی اصلی">
                <ul class="primary-menu">
                    @foreach (var item in Business.NavItems)
                    {
                        <li><a href="@item.Url" target="_blank" rel="noopener">@item.Title</a></li>
                    }
                    <li><a href="@Business.TrackingUrl" target="_blank" rel="noopener" class="menu-order-track">پیگیری سفارش</a></li>
                </ul>
            </nav>

            <button class="header-menu-toggle" type="button" aria-label="منو" aria-expanded="false"
                    @onclick="ToggleMenu">
                <span class="menu-label">منو</span>
                <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
                </svg>
            </button>
        </div>
    </div>

    <nav class="header-nav-mobile @(menuOpen ? "is-open" : "")" role="navigation" aria-label="منوی موبایل">
        <div class="container">
            <ul class="primary-menu">
                @foreach (var item in Business.NavItems)
                {
                    <li><a href="@item.Url" target="_blank" rel="noopener" @onclick="CloseMenu">@item.Title</a></li>
                }
                <li><a href="@Business.TrackingUrl" target="_blank" rel="noopener" class="menu-order-track" @onclick="CloseMenu">پیگیری سفارش</a></li>
            </ul>
        </div>
    </nav>
</header>

@code {
    [Inject] private BusinessSettings Business { get; set; } = default!;

    private bool menuOpen = false;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;
}
