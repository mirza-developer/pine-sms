@page "/"
@inject PineSms.OrderTrack.Services.BusinessSettings Business

<PageTitle>پیگیری سفارش</PageTitle>

<div class="ot-wrap">
    <div class="container">

        <nav class="ot-breadcrumbs" aria-label="مسیر">
            <ol>
                <li><a href="@Business.WebsiteUrl" target="_blank" rel="noopener">خانه</a></li>
                <li><span>پیگیری سفارش</span></li>
            </ol>
        </nav>

        <h1 class="ot-page-title">پیگیری سفارش</h1>

        <div class="ot-intro">
            <p>با تشکر از خرید و اعتماد شما به @Business.NameFa</p>
            <p>
                <strong>مرحله اول:</strong> لطفاً
                <span class="ot-highlight">پس از گذشت ۷۲ ساعت</span>
                از ثبت سفارش، با نوشتن شماره سفارش در باکس زیر، کد رهگیری پستی خود را دریافت کنید.
            </p>
            <p>
                <strong>مرحله دوم:</strong> پس از
                <span class="ot-highlight">دریافت کد مرسوله ۲۴ رقمی</span>،
                از طریق سامانه رهگیری پست از وضعیت بسته خود مطلع شوید.
            </p>
            <p class="ot-warning">
                چنانچه بسته شما بعد از ۸ روز کاری (روزهای جمعه و تعطیلات رسمی روز کاری نمی‌باشد) نرسید، فقط از طریق پیام‌رسان بله <a href="@Business.SupportBaleUrl" target="_blank"><strong dir="ltr">@Business.SupportBaleUsername</strong></a> با ما در ارتباط باشید. تماس تلفنی جوابگویی نداریم.
            </p>
        </div>

        <div class="nk-track-container">
            <h2 class="nk-track-title">پیگیری سفارش</h2>

            <div class="nk-track-form">
                <input id="orderCode"
                       class="nk-track-input"
                       type="text"
                       placeholder="شماره سفارش یا موبایل یا ایمیل خود را وارد کنید"
                       @bind="orderCode"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       disabled="@isLoading" />

                <button class="nk-track-btn" @onclick="TrackOrder" disabled="@(isLoading || string.IsNullOrWhiteSpace(orderCode))">
                    @if (isLoading)
                    {
                        <span class="spinner sm"></span>
                        <span>در حال جستجو...</span>
                    }
                    else
                    {
                        <span>پیگیری سفارش</span>
                    }
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="nk-track-alert">@errorMessage</div>
            }

            @if (result is not null)
            {
                <div class="nk-track-result">
                    <h3 class="nk-track-result-title">نتیجه پیگیری</h3>

                    <div class="nk-track-result-row">
                        <span class="nk-track-result-label">کد سفارش</span>
                        <span class="nk-track-result-value ot-ltr">@result.OrderCode</span>
                    </div>

                    <div class="nk-track-result-row">
                        <span class="nk-track-result-label">وضعیت</span>
                        <span class="nk-track-result-value">
                            <span class="nk-track-status-badge">@result.StatusTitle</span>
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(result.PostalTrackingCode))
                    {
                        <div class="nk-track-result-row">
                            <span class="nk-track-result-label">کد رهگیری پستی</span>
                            <span class="nk-track-result-value ot-ltr ot-tracking-code">@result.PostalTrackingCode</span>
                            <button class="ot-copy-btn" title="کپی کد رهگیری" onclick="navigator.clipboard.writeText('@result.PostalTrackingCode')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                            </button>
                        </div>
                        <div class="nk-track-result-row">
                            <span class="nk-track-result-value">
                                <span class="nk-track-status-badge">
                                    کد بالا را در سامانه رهگیری پست وارد کنید تا وضعیت بسته خود را مشاهده کنید
                                </span>
                            </span>
                        </div>
                    }
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Business.PostalTrackingUrl))
        {
            <a href="@Business.PostalTrackingUrl" target="_blank" rel="noopener" class="ot-post-btn">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
                ورود به سامانه رهگیری مرسولات پستی
            </a>
        }

    </div>
</div>
