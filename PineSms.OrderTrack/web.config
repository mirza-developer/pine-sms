<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
<staticContent>
  <remove fileExtension=".blat" />
  <remove fileExtension=".dat" />
  <remove fileExtension=".dll" />
  <remove fileExtension=".webcil" />
  <remove fileExtension=".json" />
  <remove fileExtension=".wasm" />
  <remove fileExtension=".woff" />
  <remove fileExtension=".woff2" />
  <remove fileExtension=".br" />
  <remove fileExtension=".gz" />
  <mimeMap fileExtension=".blat" mimeType="application/octet-stream" />
  <mimeMap fileExtension=".dll" mimeType="application/octet-stream" />
  <mimeMap fileExtension=".webcil" mimeType="application/octet-stream" />
  <mimeMap fileExtension=".dat" mimeType="application/octet-stream" />
  <mimeMap fileExtension=".json" mimeType="application/json" />
  <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
  <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
  <mimeMap fileExtension=".woff2" mimeType="application/font-woff" />
  <mimeMap fileExtension=".br" mimeType="application/octet-stream" />
  <mimeMap fileExtension=".gz" mimeType="application/octet-stream" />
</staticContent>
<httpCompression>
  <dynamicTypes>
<add mimeType="application/octet-stream" enabled="true" />
<add mimeType="application/wasm" enabled="true" />
  </dynamicTypes>
</httpCompression>
<httpProtocol>
  <customHeaders>
<remove name="Alt-Svc" />
  </customHeaders>
</httpProtocol>
<rewrite>
  <rules>
<!-- _framework files must always be served directly, never fall to SPA fallback -->
<rule name="Serve framework files" stopProcessing="true">
  <match url="^_framework/(.*)" />
  <action type="Rewrite" url="wwwroot/_framework/{R:1}" />
</rule>
<!-- Any other file that physically exists under wwwroot -->
<rule name="Serve subdir" stopProcessing="true">
  <match url="(.*)" />
  <conditions logicalGrouping="MatchAll">
<add input="{DOCUMENT_ROOT}\wwwroot\{R:1}" matchType="IsFile" />
  </conditions>
  <action type="Rewrite" url="wwwroot/{R:1}" />
</rule>
<!-- SPA fallback for all other routes -->
<rule name="SPA fallback routing" stopProcessing="true">
  <match url=".*" />
  <action type="Rewrite" url="wwwroot/index.html" />
</rule>
  </rules>
</rewrite>
  </system.webServer>

  <!-- Per-asset Cache-Control via <location> (no server-level allowedServerVariables required). -->
  <!-- Long cache for fingerprinted framework + static assets. -->
  <location path="_framework">
<system.webServer>
  <httpProtocol>
<customHeaders>
  <remove name="Cache-Control" />
  <add name="Cache-Control" value="public, max-age=31536000, immutable" />
</customHeaders>
  </httpProtocol>
</system.webServer>
  </location>
  <!-- No-store for the SPA shell. -->
  <location path="index.html">
<system.webServer>
  <httpProtocol>
<customHeaders>
  <remove name="Cache-Control" />
  <add name="Cache-Control" value="no-store, no-cache, must-revalidate" />
</customHeaders>
  </httpProtocol>
</system.webServer>
  </location>
  <location path="service-worker.js">
<system.webServer>
  <httpProtocol>
<customHeaders>
  <remove name="Cache-Control" />
  <add name="Cache-Control" value="no-store, no-cache, must-revalidate" />
</customHeaders>
  </httpProtocol>
</system.webServer>
  </location>
  <location path="appsettings.json">
<system.webServer>
  <httpProtocol>
<customHeaders>
  <remove name="Cache-Control" />
  <add name="Cache-Control" value="no-store, no-cache, must-revalidate" />
</customHeaders>
  </httpProtocol>
</system.webServer>
  </location>
</configuration>
