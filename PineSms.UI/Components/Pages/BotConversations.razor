@page "/bot/conversations"

<PageTitle>مکالمات ربات بله</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4><span class="bi bi-chat-dots-fill me-2 text-primary"></span>مکالمات ربات بله</h4>
    </div>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">نام کاربری بله (بدون @@)</label>
                    <input type="text"
                           class="form-control"
                           placeholder="مثال: john_doe"
                           value="@searchUsername"
                           @oninput="e => searchUsername = e.Value?.ToString() ?? string.Empty"
                           @onkeydown="OnSearchKeyDown" />
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-primary w-100" @onclick="LoadConversation" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <span class="bi bi-search me-1"></span>جستجو
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (hasSearched && !isLoading)
    {
        @if (messages.Count == 0)
        {
            <div class="alert alert-info mt-3">
                <span class="bi bi-info-circle me-1"></span>
                هیچ مکالمه‌ای برای نام کاربری «@lastSearchedUsername» یافت نشد.
            </div>
        }
        else
        {
            <div class="mt-3 mb-1 small text-muted">
                <span class="bi bi-person-fill me-1"></span>
                مکالمات کاربر «<strong>@lastSearchedUsername</strong>» — @messages.Count پیام
            </div>

            <div class="chat-container">
                @foreach (var msg in messages)
                {
                    <div class="d-flex @(msg.IsFromBot ? "justify-content-start" : "justify-content-end") mb-2">
                        <div class="chat-bubble @(msg.IsFromBot ? "chat-bubble-bot" : "chat-bubble-user")">
                            <div class="chat-text">@msg.MessageText</div>
                            <div class="chat-time text-muted small mt-1">
                                @PersianDateHelper.ToPersianDate(msg.SentAt)
                                @msg.SentAt.ToLocalTime().ToString("HH:mm")
                                @if (msg.IsFromBot)
                                {
                                    <span class="ms-1 badge bg-secondary">ربات</span>
                                }
                                else
                                {
                                    <span class="ms-1 badge bg-primary">کاربر</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .chat-container {
        max-height: 65vh;
        overflow-y: auto;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 0.5rem;
        border: 1px solid #dee2e6;
        margin-top: 0.5rem;
    }

    .chat-bubble {
        max-width: 75%;
        padding: 0.6rem 1rem;
        border-radius: 1rem;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .chat-bubble-user {
        background-color: #0d6efd;
        color: white;
        border-bottom-right-radius: 0.25rem;
    }

    .chat-bubble-bot {
        background-color: white;
        color: #212529;
        border: 1px solid #dee2e6;
        border-bottom-left-radius: 0.25rem;
    }

    .chat-bubble-user .chat-time {
        color: rgba(255,255,255,.75) !important;
    }
</style>
