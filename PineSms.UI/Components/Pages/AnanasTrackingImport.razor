@page "/order/ananas-tracking"

<PageTitle>ورود بارکد پستی از اکسل آناناس</PageTitle>

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header">
        <h4>ورود بارکد پستی آناناس</h4>
        <span class="badge bg-info">آپلود فایل</span>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert @alertClass alert-dismissible fade show">
            <div class="fw-semibold mb-1">@alertMessage</div>
            @if (notFoundCodes.Count > 0)
            {
                <div class="mt-2">
                    <strong>کدهای فاکتور یافت نشده (@notFoundCodes.Count عدد):</strong>
                    <div class="mt-1 p-2 bg-white rounded border small" style="max-height:100px; overflow-y:auto; direction:ltr; text-align:left;">
                        @string.Join(" ، ", notFoundCodes)
                    </div>
                </div>
            }
            <button type="button" class="btn-close" @onclick="ClearAlert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <div class="mb-4">
                <label class="form-label fw-semibold">انتخاب فایل اکسل آناناس</label>
                <InputFile class="form-control" OnChange="HandleFileSelected" accept=".xlsx,.xls" />
                <div class="form-text text-muted mt-2">
                    <ul class="mb-0 ps-3">
                        <li>فرمت فایل: <code>.xlsx</code> یا <code>.xls</code></li>
                        <li>ستون <strong>کدفاکتور</strong>: کد سفارش (برای تطبیق با سیستم)</li>
                        <li>ستون <strong>بارکد</strong>: کد رهگیری پستی</li>
                        <li>ردیف اول (سرستون) و ردیف آخر (جمع کل) نادیده گرفته می‌شوند</li>
                    </ul>
                </div>
            </div>

            @if (entries.Count > 0)
            {
                <div class="d-flex align-items-center gap-3 mb-3">
                    <span class="badge bg-primary fs-6">@entries.Count ردیف بارگذاری شد</span>
                    <span class="text-muted small">آماده برای ثبت</span>
                </div>

                <div class="table-responsive mb-3" style="max-height:300px; overflow-y:auto;">
                    <table class="table table-sm table-bordered table-hover small">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>کدفاکتور</th>
                                <th>بارکد پستی</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in entries.Take(20))
                            {
                                <tr>
                                    <td>@entry.OrderCode</td>
                                    <td>@entry.PostalTrackingCode</td>
                                </tr>
                            }
                            @if (entries.Count > 20)
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted">... و @(entries.Count - 20) ردیف دیگر</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" @onclick="HandleImport" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        ثبت در سیستم
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ClearFile" disabled="@isLoading">
                        پاک کردن
                    </button>
                </div>
            }
        </div>
    </div>
</div>
