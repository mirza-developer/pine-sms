@page "/settings/users"
@using PineSms.Core.Features.Account
@using PineSms.Core.Features.MenuLink
@using PineSms.UI.Services

<PageTitle>مدیریت کاربران</PageTitle>

@if (!AuthState.IsAdmin)
{
    Navigation.NavigateTo("/access-denied", replace: true);
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><span class="bi bi-people-fill me-2 text-primary"></span>مدیریت کاربران</h4>
        <button class="btn btn-success btn-sm" @onclick="OpenAddModal">
            <span class="bi bi-plus-circle me-1"></span>افزودن کاربر
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- User List -->
            <div class="col-12 col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white fw-semibold">کاربران</div>
                    @if (users.Count == 0)
                    {
                        <div class="card-body text-muted text-center py-4">هیچ کاربری یافت نشد.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var user in users)
                            {
                                <div class="list-group-item list-group-item-action @(selectedUser?.Id == user.Id ? "active" : "")"
                                     style="cursor:pointer"
                                     @onclick="() => SelectUser(user)">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold">@user.PersianName</div>
                                            <small class="@(selectedUser?.Id == user.Id ? "text-white-50" : "text-muted")">@user.UserName</small>
                                        </div>
                                        <div @onclick:stopPropagation="true">
                                            <button class="btn btn-outline-warning btn-sm me-1 @(selectedUser?.Id == user.Id ? "border-white text-white" : "")"
                                                    @onclick="() => OpenEditModal(user)">
                                                <span class="bi bi-pencil"></span>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm @(selectedUser?.Id == user.Id ? "border-white text-white" : "")"
                                                    @onclick="() => ConfirmDelete(user)">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Menu Links -->
            <div class="col-12 col-md-8">
                @if (selectedUser is not null)
                {
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-secondary text-white fw-semibold">
                            دسترسی‌های کاربر: @selectedUser.PersianName
                        </div>
                        <div class="card-body">
                            @if (isLoadingLinks)
                            {
                                <div class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                </div>
                            }
                            else
                            {
                                @foreach (var section in allLinks.Select(l => l.SectionLabel).Distinct())
                                {
                                    <div class="mb-3">
                                        <div class="fw-semibold text-muted mb-1">@section</div>
                                        @foreach (var link in allLinks.Where(l => l.SectionLabel == section).OrderBy(l => l.DisplayOrder))
                                        {
                                            <div class="form-check mb-1">
                                                <input class="form-check-input" type="checkbox"
                                                       id="link_@link.Id"
                                                       checked="@selectedLinkIds.Contains(link.Id)"
                                                       @onchange="e => ToggleLink(link.Id, (bool)(e.Value ?? false))" />
                                                <label class="form-check-label" for="link_@link.Id">
                                                    <span class="bi @link.IconName me-1"></span>@link.Title
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="mt-3 d-flex gap-2 align-items-center">
                                    <button class="btn btn-primary px-4" @onclick="SaveLinks" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        }
                                        ذخیره دسترسی‌ها
                                    </button>
                                    @if (!string.IsNullOrEmpty(saveMessage))
                                    {
                                        <span class="@(saveMessageSuccess ? "text-success" : "text-danger") small">@saveMessage</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-muted py-4 text-center">یک کاربر را از لیست انتخاب کنید تا دسترسی‌های او را مدیریت کنید.</div>
                }
            </div>
        </div>
    }
</div>

<!-- Add / Edit Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @if (isEditMode)
                        {
                            <span><span class="bi bi-pencil me-2"></span>ویرایش کاربر</span>
                        }
                        else
                        {
                            <span><span class="bi bi-person-plus me-2"></span>افزودن کاربر جدید</span>
                        }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2">@modalError</div>
                    }

                    @if (isEditMode)
                    {
                        <EditForm Model="updateCommand" OnValidSubmit="HandleUpdate">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">نام فارسی <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="updateCommand.PersianName" />
                                <ValidationMessage For="@(() => updateCommand.PersianName)" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">رمز عبور جدید <span class="text-muted small">(اختیاری)</span></label>
                                <InputText class="form-control" type="password" @bind-Value="updateCommand.NewPassword" placeholder="برای تغییر رمز وارد کنید" />
                                <ValidationMessage For="@(() => updateCommand.NewPassword)" class="text-danger small" />
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button type="submit" class="btn btn-success" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    ذخیره
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">انصراف</button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <EditForm Model="createCommand" OnValidSubmit="HandleCreate">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">نام کاربری <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="createCommand.UserName" />
                                <ValidationMessage For="@(() => createCommand.UserName)" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">نام فارسی <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="createCommand.PersianName" />
                                <ValidationMessage For="@(() => createCommand.PersianName)" class="text-danger small" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">رمز عبور <span class="text-danger">*</span></label>
                                <InputText class="form-control" type="password" @bind-Value="createCommand.Password" />
                                <ValidationMessage For="@(() => createCommand.Password)" class="text-danger small" />
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button type="submit" class="btn btn-success" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    ایجاد
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">انصراف</button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirm Modal -->
@if (deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><span class="bi bi-exclamation-triangle me-2"></span>تأیید حذف</h5>
                    <button type="button" class="btn-close" @onclick="() => deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    آیا از حذف کاربر «<strong>@deleteTarget.PersianName</strong>» مطمئن هستید؟<br/>
                    <small class="text-muted">تمام دسترسی‌های منو این کاربر نیز حذف خواهد شد.</small>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        حذف
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="() => deleteTarget = null">انصراف</button>
                </div>
            </div>
        </div>
    </div>
}
