@page "/customer/add"
@rendermode InteractiveServer
@using PineSms.UI.Services
@using PineSms.Core.Features.Customer
@inject ApiClientService ApiClient
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>افزودن مشتری</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container mt-4" style="direction:rtl;">
    <h4 class="mb-4">➕ افزودن مشتری جدید</h4>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert @alertClass alert-dismissible">
            @alertMessage
            <button type="button" class="btn-close" @onclick="() => alertMessage = string.Empty"></button>
        </div>
    }

    <div class="card shadow-sm p-4">
        <EditForm Model="command" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">شماره موبایل <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="command.PhoneNumber" placeholder="مثال: 9903063085" />
                    <small class="text-muted">۱۰ رقم بدون صفر ابتدایی</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label">نام</label>
                    <InputText class="form-control" @bind-Value="command.Name" placeholder="نام کامل" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">جنسیت</label>
                    <InputSelect class="form-select" @bind-Value="command.Gender">
                        <option value="">انتخاب کنید</option>
                        <option value="1">مرد</option>
                        <option value="2">زن</option>
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">سال تولد</label>
                    <InputNumber class="form-control" @bind-Value="command.BirthYear" placeholder="مثال: 1370" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">تاریخ تولد (شمسی)</label>
                    <InputText class="form-control" @bind-Value="command.BirthDate" placeholder="مثال: 1370/01/01" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-success" disabled="@isLoading">
                        @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        ثبت مشتری
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private InsertCustomerCommand command = new();
    private string alertMessage = string.Empty;
    private string alertClass = "alert-success";
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        try
        {
            var (success, message) = await ApiClient.InsertCustomerAsync(command);
            alertClass = success ? "alert-success" : "alert-danger";
            alertMessage = message;
            if (success) command = new InsertCustomerCommand();
        }
        catch
        {
            alertClass = "alert-danger";
            alertMessage = "خطا در اتصال به سرور";
        }
        finally
        {
            isLoading = false;
        }
    }
}
