@page "/customer/add"

<PageTitle>@(IsUpdateMode ? "ویرایش مشتری" : "افزودن مشتری")</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header">
        <h4>@(IsUpdateMode ? "ویرایش مشتری" : "افزودن مشتری جدید")</h4>
        <span class="badge @(IsUpdateMode ? "bg-warning text-dark" : "bg-success")">
            @(IsUpdateMode ? "ویرایش اطلاعات" : "فرم ورود دستی")
        </span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <EditForm Model="command" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">شماره موبایل <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">0</span>
                            <InputText class="form-control" @bind-Value="command.PhoneNumber" placeholder="9903063085" />
                            <button type="button" class="btn btn-outline-primary" @onclick="HandleSearch" disabled="@isSearching">
                                @if (isSearching)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <span class="bi bi-search"></span>
                                }
                            </button>
                        </div>
                        <div class="form-text text-muted">۱۰ رقم، شروع با ۹ (بدون صفر ابتدایی)</div>
                        <ValidationMessage For="@(() => command.PhoneNumber)" class="text-danger small" />

                        @if (searchFound == true)
                        {
                            <div class="alert alert-success alert-sm py-1 px-2 mt-1 mb-0 small">
                                <span class="bi bi-check-circle-fill me-1"></span>@searchMessage
                            </div>
                        }
                        else if (searchFound == false)
                        {
                            <div class="alert alert-warning alert-sm py-1 px-2 mt-1 mb-0 small">
                                <span class="bi bi-exclamation-triangle-fill me-1"></span>@searchMessage
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">نام و نام‌خانوادگی</label>
                        <InputText class="form-control" @bind-Value="command.Name" placeholder="نام کامل (اختیاری)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">جنسیت</label>
                        <InputSelect class="form-select" @bind-Value="command.Gender">
                            <option value="">-- انتخاب --</option>
                            <option value="1">مرد</option>
                            <option value="2">زن</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">سال تولد</label>
                        <InputNumber class="form-control" @bind-Value="command.BirthYear" placeholder="مثال: ۱۳۷۰" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">تاریخ تولد (شمسی)</label>
                        <PersianDatePicker @bind-Value="command.BirthDate" />
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" id="isTesterCheck" @bind-Value="command.IsTester" />
                            <label class="form-check-label fw-semibold" for="isTesterCheck">مشتری آزمایشی (در هر دسته ارسال پیامک دریافت می‌کند)</label>
                        </div>
                    </div>
                    <div class="col-12 mt-3">
                        <div class="btn-group-rtl">
                            <button type="submit" class="btn @(IsUpdateMode ? "btn-warning" : "btn-success") px-4" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @if (IsUpdateMode)
                                {
                                    <span class="bi bi-pencil-square me-1"></span>
                                    <span>ویرایش مشتری</span>
                                }
                                else
                                {
                                    <span class="bi bi-check-circle me-1"></span>
                                    <span>ثبت مشتری</span>
                                }
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="Reset">
                                <span class="bi bi-arrow-counterclockwise me-1"></span>پاک کردن
                            </button>
                        </div>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

