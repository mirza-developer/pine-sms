@page "/sms/jobs"

<PageTitle>گزارش ارسال‌های زمان‌بندی شده</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4><span class="bi bi-calendar-check-fill me-2 text-primary"></span>گزارش ارسال‌های زمان‌بندی شده</h4>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadJobs" disabled="@isLoading">
            @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
            بروزرسانی
        </button>
    </div>

    @if (jobs.Count == 0 && !isLoading)
    {
        <div class="alert alert-info mt-3">هیچ ارسال زمان‌بندی شده‌ای وجود ندارد.</div>
    }

    @foreach (var job in jobs)
    {
        <div class="card shadow-sm mt-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>شناسه #@job.Id</strong>
                    <span class="ms-2 text-muted small">از @job.FromNumber</span>
                </div>
                <span class="text-muted small">@PersianDateHelper.ToPersianDate(job.CreatedAt)</span>
            </div>
            <div class="card-body p-3">
                <div class="mb-2 p-2 bg-light rounded border small text-muted">@job.MessageText</div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th>قسمت</th>
                                <th>زمان ارسال</th>
                                <th>تعداد گیرندگان</th>
                                <th>وضعیت</th>
                                <th>ارسال شده</th>
                                <th>زمان اجرا</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var part in job.Parts)
                            {
                                <tr>
                                    <td>@part.PartNumber</td>
                                    <td>@PersianDateHelper.ToPersianDate(part.ScheduledAt) @part.ScheduledAt.ToLocalTime().ToString("HH:mm")</td>
                                    <td>@part.RecipientCount</td>
                                    <td>
                                        <span class="badge @GetBadgeClass(part.Status)">@TranslateStatus(part.Status)</span>
                                    </td>
                                    <td>@part.SentCount</td>
                                    <td>
                                        @if (part.ExecutedAt.HasValue)
                                        {
                                            @PersianDateHelper.ToPersianDate(part.ExecutedAt.Value)
                                            @(" ")
                                            @part.ExecutedAt.Value.ToLocalTime().ToString("HH:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @{
                    int completed = job.Parts.Count(p => p.Status == "Completed");
                    int total = job.Parts.Count;
                    int pct = total > 0 ? (completed * 100 / total) : 0;
                }
                <div class="mt-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>پیشرفت: @completed از @total قسمت</span>
                        <span>@pct%</span>
                    </div>
                    <div class="progress" style="height:8px;">
                        <div class="progress-bar @(completed == total ? "bg-success" : "bg-primary")"
                             role="progressbar" style="width:@pct%"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

