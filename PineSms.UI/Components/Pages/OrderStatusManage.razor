@page "/order/statuses"

<PageTitle>مدیریت وضعیت‌های سفارش</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4><span class="bi bi-tags-fill me-2 text-primary"></span>مدیریت وضعیت‌های سفارش</h4>
        <button class="btn btn-success btn-sm" @onclick="OpenAddModal">
            <span class="bi bi-plus-circle me-1"></span>افزودن وضعیت
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center mt-4"><span class="spinner-border text-primary"></span></div>
    }
    else if (statuses.Count == 0)
    {
        <div class="alert alert-info mt-3">هیچ وضعیت سفارشی تعریف نشده است.</div>
    }
    else
    {
        <div class="card shadow-sm mt-3">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>کد</th>
                            <th>عنوان</th>
                            <th>آخرین تغییر</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var status in statuses)
                        {
                            <tr>
                                <td>@status.Id</td>
                                <td><code>@status.Code</code></td>
                                <td>@status.Title</td>
                                <td class="text-muted small">@PersianDateHelper.ToPersianDate(status.LastChange)</td>
                                <td class="text-end">
                                    <button class="btn btn-outline-warning btn-sm me-1" @onclick="() => OpenEditModal(status)">
                                        <span class="bi bi-pencil"></span>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(status)">
                                        <span class="bi bi-trash"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editCommand.Id.HasValue ? "ویرایش وضعیت" : "افزودن وضعیت جدید")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editCommand" OnValidSubmit="HandleSave">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">کد <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="editCommand.Code" placeholder="مثال: PENDING" />
                            <ValidationMessage For="@(() => editCommand.Code)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">عنوان <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="editCommand.Title" placeholder="مثال: در انتظار پردازش" />
                            <ValidationMessage For="@(() => editCommand.Title)" class="text-danger small" />
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="submit" class="btn btn-success" disabled="@isSaving">
                                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                ذخیره
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">انصراف</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (deleteTarget != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><span class="bi bi-exclamation-triangle me-2"></span>تأیید حذف</h5>
                    <button type="button" class="btn-close" @onclick="() => deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    آیا از حذف وضعیت «<strong>@deleteTarget.Title</strong>» مطمئن هستید؟
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        حذف
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="() => deleteTarget = null">انصراف</button>
                </div>
            </div>
        </div>
    </div>
}
