@page "/sms/send"

<PageTitle>ارسال پیامک</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="page-header">
        <h4><span class="bi bi-chat-dots-fill me-2 text-primary"></span>ارسال پیامک</h4>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert @alertClass alert-dismissible">
            @alertMessage
            <button type="button" class="btn-close" @onclick="() => alertMessage = string.Empty"></button>
        </div>
    }

    <div class="row g-3">
        <!-- LEFT PANEL -->
        <div class="col-md-4">
            <!-- Date filter -->
            <div class="card shadow-sm p-3">
                <h6 class="mb-3">فیلتر بازه زمانی</h6>
                <div class="mb-2">
                    <select class="form-select" @bind="selectedRange" @bind:after="OnRangeChanged">
                        <option value="LastWeek">یک هفته اخیر</option>
                        <option value="LastTwoWeeks">دو هفته اخیر</option>
                        <option value="LastMonth">یک ماه اخیر</option>
                        <option value="LastSeason">یک فصل اخیر</option>
                        <option value="LastYear">یک سال اخیر</option>
                        <option value="Custom">سفارشی</option>
                    </select>
                </div>
                @if (selectedRange == "Custom")
                {
                    <div class="mb-2">
                        <label class="form-label">از تاریخ</label>
                        <PersianDatePicker Value="@customFromStr" ValueChanged="OnCustomFromChanged" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">تا تاریخ</label>
                        <PersianDatePicker Value="@customToStr" ValueChanged="OnCustomToChanged" />
                    </div>
                }
                <button class="btn btn-outline-primary btn-sm" @onclick="LoadCustomers" disabled="@isLoadingCustomers">
                    @if (isLoadingCustomers) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    جستجوی مشتریان
                </button>
            </div>

            <!-- SMS settings -->
            <div class="card shadow-sm p-3 mt-3">
                <h6 class="mb-3">تنظیمات پیامک</h6>
                <div class="mb-2">
                    <label class="form-label">شماره فرستنده</label>
                    <input type="text" class="form-control" @bind="fromNumber" placeholder="شماره پنل" />
                </div>
                <div class="mb-2">
                    <label class="form-label">متن پیامک</label>
                    <textarea class="form-control" rows="4" @bind="messageText" placeholder="متن پیامک خود را وارد کنید..."></textarea>
                </div>

                <!-- Send mode toggle -->
                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="scheduleToggle"
                               @bind="scheduleEnabled" />
                        <label class="form-check-label" for="scheduleToggle">ارسال زمان‌بندی شده / چند مرحله‌ای</label>
                    </div>
                </div>

                @if (!scheduleEnabled)
                {
                    <!-- Instant send -->
                    <button class="btn btn-success w-100" @onclick="HandleSendSms"
                            disabled="@(isSending || selectedIds.Count == 0)">
                        @if (isSending) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        ارسال فوری به @selectedIds.Count نفر
                    </button>
                }
                else
                {
                    <!-- Schedule options -->
                    <div class="border rounded p-3 bg-light mb-3">
                        <h6 class="mb-3 text-primary">تنظیمات زمان‌بندی</h6>

                        <div class="mb-2">
                            <label class="form-label">تعداد مراحل (قسمت‌ها)</label>
                            <input type="number" class="form-control" min="1" max="100" @bind="numberOfParts" />
                            <div class="form-text">گیرندگان به @numberOfParts قسمت مساوی تقسیم می‌شوند</div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">فاصله بین هر مرحله (دقیقه)</label>
                            <input type="number" class="form-control" min="0" @bind="delayMinutes" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">تاریخ شروع ارسال (اختیاری)</label>
                            <PersianDatePicker @bind-Value="firstSendDateStr" />
                            <div class="form-text">در صورت خالی بودن، از همین لحظه شروع می‌شود</div>
                        </div>

                        @if (!string.IsNullOrEmpty(firstSendDateStr))
                        {
                            <div class="mb-2">
                                <label class="form-label">ساعت شروع ارسال</label>
                                <input type="time" class="form-control" @bind="firstSendTime" />
                            </div>
                        }

                        @if (numberOfParts > 1 && selectedIds.Count > 0)
                        {
                            <div class="alert alert-info py-2 small mb-2">
                                هر مرحله تقریباً @((int)Math.Ceiling(selectedIds.Count / (double)numberOfParts)) نفر دریافت می‌کنند
                            </div>
                        }
                    </div>

                    <button class="btn btn-primary w-100" @onclick="HandleScheduleSms"
                            disabled="@(isScheduling || selectedIds.Count == 0)">
                        @if (isScheduling) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        زمان‌بندی ارسال به @selectedIds.Count نفر
                    </button>
                }
            </div>

            <!-- Jobs report (inline, last 5) -->
            @if (recentJobs.Count > 0)
            {
                <div class="card shadow-sm p-3 mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">آخرین ارسال‌های زمان‌بندی شده</h6>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadRecentJobs" title="بروزرسانی">↺</button>
                    </div>
                    @foreach (var job in recentJobs)
                    {
                        <div class="border rounded p-2 mb-2 small">
                            <div class="d-flex justify-content-between">
                                <strong>شناسه #@job.Id</strong>
                                <span class="text-muted">@PersianDateHelper.ToPersianDate(job.CreatedAt)</span>
                            </div>
                            <div class="text-truncate text-muted">@job.MessageText</div>
                            <div class="mt-1">
                                @foreach (var part in job.Parts)
                                {
                                    <span class="badge @GetPartBadgeClass(part.Status) me-1">
                                        قسمت @part.PartNumber – @TranslateStatus(part.Status)
                                    </span>
                                }
                            </div>
                        </div>
                    }
                    <NavLink class="btn btn-sm btn-outline-primary w-100 mt-1" href="sms/jobs">
                        مشاهده همه گزارشات
                    </NavLink>
                </div>
            }
        </div>

        <!-- RIGHT PANEL: customer list -->
        <div class="col-md-8">
            <div class="card shadow-sm p-3">
                <!-- Header row -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">
                        لیست مشتریان
                        <span class="badge bg-secondary ms-1">@customers.Count نفر</span>
                        <span class="badge bg-primary ms-1">@FilteredCustomers.Count() نمایش</span>
                        <span class="badge bg-success ms-1">@selectedIds.Count انتخاب</span>
                    </h6>
                </div>

                <!-- Filter row -->
                <div class="row g-2 mb-3 align-items-end">
                    <div class="col-sm-7">
                        <label class="form-label form-label-sm mb-1 fw-semibold">
                            <span class="bi bi-search me-1"></span>جستجو در شماره‌ها
                        </label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control"
                                   placeholder="بخشی از شماره موبایل..."
                                   @bind="phoneFilter"
                                   @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(phoneFilter))
                            {
                                <button class="btn btn-outline-secondary" type="button"
                                        @onclick="() => phoneFilter = string.Empty"
                                        title="پاک کردن فیلتر">
                                    <span class="bi bi-x-lg"></span>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="col-sm-5">
                        <label class="form-label form-label-sm mb-1 fw-semibold">
                            <span class="bi bi-funnel me-1"></span>نوع مشتری
                        </label>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" id="testerFilter"
                                   @bind="showTestersOnly" />
                            <label class="form-check-label" for="testerFilter">فقط مشتریان آزمایشی</label>
                        </div>
                    </div>
                </div>

                <div class="table-responsive-wrapper" style="max-height:500px; overflow-y:auto;">
                    <table class="table table-sm table-hover table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:40px; text-align:center;">
                                    <input type="checkbox"
                                           checked="@allSelected"
                                           @onchange="ToggleAll"
                                           title="انتخاب/حذف همه نمایش‌داده‌شده" />
                                </th>
                                <th>شماره موبایل</th>
                                <th>نام</th>
                                <th>جنسیت</th>
                                <th>تاریخ ثبت</th>
                                <th>آخرین استفاده</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in FilteredCustomers)
                            {
                                <tr class="@(selectedIds.Contains(c.Id) ? "table-primary" : "")"
                                    style="cursor:pointer;" @onclick="() => ToggleRow(c.Id)">
                                    <td style="text-align:center;">
                                        <input type="checkbox"
                                               checked="@selectedIds.Contains(c.Id)"
                                               @onchange="e => ToggleSelection(c.Id, (bool)(e.Value ?? false))"
                                               @onclick:stopPropagation="true" />
                                    </td>
                                    <td>@c.PhoneNumber</td>
                                    <td>@(c.Name ?? "-")</td>
                                    <td>@(c.Gender == 1 ? "مرد" : c.Gender == 2 ? "زن" : "-")</td>
                                    <td>@PersianDateHelper.ToPersianDate(c.SaveDate)</td>
                                    <td>@(c.LastUsageDate.HasValue ? PersianDateHelper.ToPersianDate(c.LastUsageDate.Value) : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (!customers.Any() && !isLoadingCustomers)
                    {
                        <div class="text-center text-muted py-4">
                            <span class="bi bi-person-x fs-3 d-block mb-2"></span>
                            ابتدا بازه زمانی را انتخاب کرده و جستجو کنید
                        </div>
                    }
                    else if (customers.Any() && !FilteredCustomers.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <span class="bi bi-search fs-3 d-block mb-2"></span>
                            هیچ مشتری با این فیلترها یافت نشد
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

