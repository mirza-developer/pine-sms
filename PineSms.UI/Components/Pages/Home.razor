@page "/"
@using PineSms.UI.Services
@using PineSms.Core.Features.MenuLink
@inject MenuAccessStateService MenuAccess

@code {
    private List<MenuLinkDto> accessibleLinks = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await MenuAccess.EnsureLoadedAsync();
            accessibleLinks = MenuAccess.GetLinks().Where(l => l.Url != "/").ToList();
            StateHasChanged();
        }
    }

    private static string GetCardColor(string iconName) => iconName switch
    {
        var n when n.Contains("person") => "success",
        var n when n.Contains("excel") => "info",
        var n when n.Contains("box") => "warning",
        var n when n.Contains("tags") => "primary",
        var n when n.Contains("key") => "secondary",
        var n when n.Contains("chat") => "dark",
        _ => "primary"
    };
}

<div class="container-fluid px-3 px-md-4 mt-4">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var link in accessibleLinks)
        {
            var color = GetCardColor(link.IconName);
            <div class="col">
                <div class="card h-100 text-center shadow-sm border-0">
                    <div class="card-body py-4">
                        <div class="mb-3">
                            <span class="bi @link.IconName text-@color" style="font-size:2.5rem;"></span>
                        </div>
                        <h5 class="card-title fw-semibold">@link.Title</h5>
                        <a href="@link.Url.TrimStart('/')" class="btn btn-@color btn-sm px-4">شروع</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

