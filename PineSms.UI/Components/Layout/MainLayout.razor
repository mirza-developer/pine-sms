@inherits LayoutComponentBase
@if (!isAuthInitialized)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">در حال بارگذاری...</span>
        </div>
    </div>
}
else
{
    <div class="page" style="direction:rtl;">
        <div class="sidebar">
            <div class="sidebar-brand">
                <a class="brand-link" href="">
                    <span class="brand-icon bi bi-tree-fill"></span>
                    <div class="brand-text">
                        <span class="brand-name">PineSms</span>
                        <span class="brand-tagline">مدیریت پیامک</span>
                    </div>
                </a>
                <button class="toggler-btn" title="@TogglerTitle" @onclick="ToggleNavMenu">
                    <span class="bi @TogglerIconClass"></span>
                </button>
            </div>

            <div class="@NavMenuCssClass nav-scrollable">
                <NavMenu />

                @if (AuthState.IsAuthenticated)
                {
                    <div class="sidebar-footer">
                        <div class="sidebar-user">
                            <span class="bi bi-person-circle sidebar-user-icon"></span>
                            <span class="sidebar-user-name">@AuthState.PersianName</span>
                        </div>
                        <button class="sidebar-logout-btn" @onclick="Logout">
                            <span class="bi bi-box-arrow-right me-1"></span>خروج
                        </button>
                    </div>
                }
            </div>
        </div>

        <main>
            <div class="top-row px-3 px-md-4 d-flex align-items-center gap-2">
                <button class="toggler-btn toggler-btn--light d-md-none" title="@TogglerTitle" @onclick="ToggleNavMenu">
                    <span class="bi @TogglerIconClass"></span>
                </button>
                <span class="fw-semibold text-secondary d-md-none" style="font-size:.85rem;">PineSms</span>

                @if (AuthState.IsAuthenticated)
                {
                    <span class="text-muted small d-none d-md-flex align-items-center gap-1">
                        <span class="bi bi-person-circle"></span>@AuthState.PersianName
                    </span>
                    <button class="btn btn-sm btn-outline-danger ms-auto d-none d-md-inline-flex align-items-center gap-1" @onclick="Logout">
                        <span class="bi bi-box-arrow-right"></span>خروج
                    </button>
                }
            </div>
            <article class="content px-3 px-md-4">
                @Body
            </article>
        </main>
    </div>
}

<ReconnectModal />
<NotificationContainer Position="NotificationPosition.TopRight" />

